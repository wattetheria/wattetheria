{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_did", "stats"],
  "properties": {
    "agent_did": {"type": "string"},
    "public_id": {"type": "string"},
    "controller_id": {"type": "string"},
    "model_provider": {"type": "string"},
    "personality_params": {"type": "object"},
    "capabilities_granted": {
      "type": "array",
      "items": {"type": "string"}
    },
    "controller_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "controller_kind": {"type": "string"},
        "controller_ref": {"type": "string"},
        "controller_node_id": {"type": "string"},
        "ownership_scope": {"type": "string"},
        "active": {"type": "boolean"}
      }
    },
    "wallet_adapter": {"type": "string"},
    "subnet_memberships": {
      "type": "array",
      "items": {"type": "string"}
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["power", "watt", "reputation", "capacity"],
      "properties": {
        "power": {"type": "integer"},
        "watt": {"type": "integer"},
        "reputation": {"type": "integer"},
        "capacity": {"type": "integer"}
      }
    }
  }
}
