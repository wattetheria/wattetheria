{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillManifest",
  "type": "object",
  "required": ["id", "version", "entry", "required_caps", "resources", "trust"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"},
    "entry": {"type": "string", "minLength": 1},
    "required_caps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "resources": {
      "type": "array",
      "items": {"type": "string"}
    },
    "trust": {
      "type": "string",
      "enum": ["trusted", "verified", "untrusted"]
    },
    "conformance_report": {
      "type": ["string", "null"]
    },
    "signature_file": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
