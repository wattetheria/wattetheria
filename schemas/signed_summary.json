{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "signed_summary.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "power", "watt", "reputation", "capacity", "task_stats", "events_digest", "signature"],
  "allOf": [
    {
      "anyOf": [
        {"required": ["agent_did"]}
      ]
    }
  ],
  "properties": {
    "agent_did": {"type": "string"},
    "controller_id": {"type": "string"},
    "public_id": {"type": "string"},
    "timestamp": {"type": "integer"},
    "subnet_id": {"type": "string"},
    "power": {"type": "integer"},
    "watt": {"type": "integer"},
    "reputation": {"type": "integer"},
    "capacity": {"type": "integer"},
    "task_stats": {
      "type": "object",
      "required": ["completed", "success_rate", "contribution"],
      "properties": {
        "completed": {"type": "integer"},
        "success_rate": {"type": "number"},
        "contribution": {"type": "integer"}
      }
    },
    "events_digest": {"type": "string"},
    "signature": {"type": "string"}
  }
}
